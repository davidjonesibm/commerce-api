# =============================================================================
# Environment Variables — Commerce API
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file to .env:     cp .env.example .env
#   2. Edit .env with your values (the defaults below work for local dev)
#   3. Docker Compose auto-loads .env from the project root
#
# SECURITY:
#   - NEVER commit .env to git (it should be in .gitignore)
#   - .env.example is safe to commit because it has placeholder/dev-only values
#   - For production, use Docker secrets or a vault, not .env files
# =============================================================================

# --- PostgreSQL Configuration ---
# These are used by the postgres container on first startup to create
# the superuser and default database.
POSTGRES_USER=commerce_user
POSTGRES_PASSWORD=commerce_pass_dev
POSTGRES_DB=commerce

# --- Application Connection String ---
# Used by the .NET API to connect to PostgreSQL.
# Host=db → "db" is the Docker Compose service name (resolved via Docker DNS)
# Port=5432 → The container's INTERNAL port (not the host-mapped 5433)
CONNECTION_STRING=Host=db;Port=5432;Database=commerce;Username=commerce_user;Password=commerce_pass_dev
